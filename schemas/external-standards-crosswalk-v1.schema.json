{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/external-standards-crosswalk-v1.schema.json",
  "title": "ISRAS External Standards Crosswalk v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "reviewed_on",
    "certification_claim",
    "baselines",
    "mappings",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "ISRAS-EXTERNAL-CROSSWALK-V1"
    },
    "status": {
      "enum": [
        "DEVELOPMENT_CANDIDATE",
        "REVIEWED",
        "ACCEPTED"
      ]
    },
    "reviewed_on": {
      "type": "string",
      "format": "date"
    },
    "certification_claim": {
      "const": false
    },
    "baselines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "baseline_id",
          "name",
          "version",
          "pin_status",
          "source_identifier"
        ],
        "properties": {
          "baseline_id": {
            "type": "string",
            "pattern": "^[A-Z0-9_.-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "pin_status": {
            "enum": [
              "PINNED",
              "REVIEW_REQUIRED"
            ]
          },
          "source_identifier": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "state",
          "external_references",
          "remaining_responsibility"
        ],
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^ISRAS-[A-Z]{2,4}-[0-9]{3}$"
          },
          "state": {
            "enum": [
              "COVERED",
              "PARTIALLY_COVERED",
              "PROJECT_RESPONSIBILITY",
              "NOT_APPLICABLE"
            ]
          },
          "external_references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "baseline_id",
                "reference"
              ],
              "properties": {
                "baseline_id": {
                  "type": "string"
                },
                "reference": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "remaining_responsibility": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 20
      }
    }
  }
}
