{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/authority-boundary-record-v1.schema.json",
  "title": "ISRAS Authority Boundary Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "boundary_id",
    "repository",
    "name",
    "boundary_type",
    "description",
    "source_component",
    "target_component",
    "requested_operations",
    "identity_model",
    "minimum_authority",
    "explicit_denials",
    "authorization",
    "privilege_propagation",
    "database_authority",
    "role_accumulation",
    "elevation_and_break_glass",
    "revocation",
    "audit",
    "hostile_tests",
    "maturity",
    "evidence_paths",
    "owner",
    "review"
  ],
  "properties": {
    "schema_version": {
      "const": "ISRAS-AUTHORITY-BOUNDARY-V1"
    },
    "boundary_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "boundary_type": {
      "enum": [
        "AUTHENTICATION",
        "SESSION",
        "PROCESS",
        "SERVICE",
        "API",
        "QUEUE",
        "WORKER",
        "DATABASE",
        "MODULE",
        "ADMINISTRATIVE",
        "DEPLOYMENT",
        "BACKGROUND_TASK",
        "LIFECYCLE",
        "TRUST",
        "OTHER"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "source_component": {
      "type": "string",
      "minLength": 1
    },
    "target_component": {
      "type": "string",
      "minLength": 1
    },
    "requested_operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "identity_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acting_identity",
        "credential_type",
        "service_identity_separate_from_user_identity",
        "administrative_identity_separate_from_ordinary_identity",
        "credentials_reused_across_unrelated_boundaries"
      ],
      "properties": {
        "acting_identity": {
          "type": "string",
          "minLength": 1
        },
        "credential_type": {
          "type": "string",
          "minLength": 1
        },
        "service_identity_separate_from_user_identity": {
          "type": "boolean"
        },
        "administrative_identity_separate_from_ordinary_identity": {
          "type": "boolean"
        },
        "credentials_reused_across_unrelated_boundaries": {
          "type": "boolean"
        }
      }
    },
    "minimum_authority": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "explicit_denials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deny_by_default",
        "independent_at_boundary",
        "decision_point",
        "delegation_scoped_to_operation"
      ],
      "properties": {
        "deny_by_default": {
          "type": "boolean"
        },
        "independent_at_boundary": {
          "type": "boolean"
        },
        "decision_point": {
          "type": "string",
          "minLength": 1
        },
        "delegation_scoped_to_operation": {
          "type": "boolean"
        }
      }
    },
    "privilege_propagation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "automatic_propagation_prohibited",
        "unrestricted_execution_context_prohibited",
        "retry_replay_recovery_cannot_increase_authority"
      ],
      "properties": {
        "automatic_propagation_prohibited": {
          "type": "boolean"
        },
        "unrestricted_execution_context_prohibited": {
          "type": "boolean"
        },
        "retry_replay_recovery_cannot_increase_authority": {
          "type": "boolean"
        }
      }
    },
    "database_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicable",
        "runtime_uses_owner_or_superuser",
        "migration_authority_separate_from_runtime",
        "operation_appropriate_roles"
      ],
      "properties": {
        "applicable": {
          "type": "boolean"
        },
        "runtime_uses_owner_or_superuser": {
          "type": "boolean"
        },
        "migration_authority_separate_from_runtime": {
          "type": "boolean"
        },
        "operation_appropriate_roles": {
          "type": "boolean"
        }
      }
    },
    "role_accumulation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluated",
        "unrestricted_authority_prevented",
        "control"
      ],
      "properties": {
        "evaluated": {
          "type": "boolean"
        },
        "unrestricted_authority_prevented": {
          "type": "boolean"
        },
        "control": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "elevation_and_break_glass": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applicable",
        "explicit",
        "time_bounded",
        "attributable",
        "audited",
        "reviewed_after_use"
      ],
      "properties": {
        "applicable": {
          "type": "boolean"
        },
        "explicit": {
          "type": "boolean"
        },
        "time_bounded": {
          "type": "boolean"
        },
        "attributable": {
          "type": "boolean"
        },
        "audited": {
          "type": "boolean"
        },
        "reviewed_after_use": {
          "type": "boolean"
        }
      }
    },
    "revocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supported",
        "session_invalidation_supported",
        "queued_or_retried_work_reauthorized"
      ],
      "properties": {
        "supported": {
          "type": "boolean"
        },
        "session_invalidation_supported": {
          "type": "boolean"
        },
        "queued_or_retried_work_reauthorized": {
          "type": "boolean"
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acting_principal",
        "effective_authority",
        "requested_action",
        "decision",
        "result",
        "correlation"
      ],
      "properties": {
        "acting_principal": {
          "type": "boolean"
        },
        "effective_authority": {
          "type": "boolean"
        },
        "requested_action": {
          "type": "boolean"
        },
        "decision": {
          "type": "boolean"
        },
        "result": {
          "type": "boolean"
        },
        "correlation": {
          "type": "boolean"
        }
      }
    },
    "hostile_tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "test_class",
          "applicability",
          "status",
          "evidence_path"
        ],
        "properties": {
          "test_class": {
            "type": "string",
            "minLength": 3
          },
          "applicability": {
            "enum": [
              "APPLICABLE",
              "NOT_APPLICABLE"
            ]
          },
          "status": {
            "enum": [
              "PASS",
              "FAIL",
              "NOT_RUN",
              "NOT_APPLICABLE"
            ]
          },
          "evidence_path": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "maturity": {
      "enum": [
        "DOCUMENTED",
        "IMPLEMENTED",
        "VALIDATED",
        "ACCEPTED"
      ]
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewer",
        "date"
      ],
      "properties": {
        "status": {
          "enum": [
            "DRAFT",
            "PASS",
            "FAIL",
            "ACCEPTED"
          ]
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
