{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/engineering-standards-impact-assessment-v1.schema.json",
  "title": "ISRAS Engineering Standards Impact Assessment v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assessment_id",
    "status",
    "repository",
    "assessment_date",
    "current_baseline",
    "candidate_release",
    "trigger",
    "phase_context",
    "controls",
    "decision",
    "decision_justification",
    "reviewer",
    "approval",
    "completed_at"
  ],
  "$defs": {
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "signed_release_tag",
        "commit",
        "source_manifest_sha256"
      ],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "signed_release_tag": {
          "type": "string",
          "minLength": 3
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "source_manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "exception": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "record_id",
        "status",
        "review_by"
      ],
      "properties": {
        "record_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "OPEN",
            "APPROVED",
            "CLOSED",
            "EXPIRED"
          ]
        },
        "review_by": {
          "type": "string",
          "format": "date"
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": "ISRAS-ESIA-V1"
    },
    "assessment_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "status": {
      "enum": [
        "DRAFT",
        "COMPLETE",
        "ACCEPTED",
        "REJECTED"
      ]
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "assessment_date": {
      "type": "string",
      "format": "date"
    },
    "current_baseline": {
      "$ref": "#/$defs/release"
    },
    "candidate_release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "signed_release_tag",
        "commit",
        "source_manifest_sha256",
        "accepted"
      ],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "signed_release_tag": {
          "type": "string",
          "minLength": 3
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "source_manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "accepted": {
          "type": "boolean"
        }
      }
    },
    "trigger": {
      "enum": [
        "NEW_ACCEPTED_RELEASE",
        "ACCEPTED_RELEASE_REVISION",
        "APPLICABILITY_CHANGE",
        "NEW_ARCHITECTURE_BOUNDARY",
        "EXCEPTION_REVIEW",
        "PHASE_REVIEW_FINDING",
        "CANDIDATE_PLANNING"
      ]
    },
    "phase_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "in_progress",
        "entry_baseline_locked"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "in_progress": {
          "type": "boolean"
        },
        "entry_baseline_locked": {
          "type": "boolean"
        }
      }
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "classification",
          "justification",
          "affected_artifacts",
          "owner",
          "target_phase_or_milestone",
          "validation_impact",
          "acceptance_impact",
          "exception_or_deferment"
        ],
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^ISRAS-[A-Z]{3}-[0-9]{3}$"
          },
          "classification": {
            "enum": [
              "ALREADY_SATISFIED",
              "REQUIRES_DOCUMENTATION",
              "REQUIRES_IMPLEMENTATION",
              "REQUIRES_VALIDATION",
              "REQUIRES_ACCEPTANCE_UPDATE",
              "REQUIRES_FUTURE_WORK",
              "NOT_APPLICABLE"
            ]
          },
          "justification": {
            "type": "string",
            "minLength": 10
          },
          "affected_artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "target_phase_or_milestone": {
            "type": "string",
            "minLength": 1
          },
          "validation_impact": {
            "type": "string",
            "minLength": 3
          },
          "acceptance_impact": {
            "type": "string",
            "minLength": 3
          },
          "exception_or_deferment": {
            "$ref": "#/$defs/exception"
          }
        }
      }
    },
    "decision": {
      "enum": [
        "ADOPT_NOW",
        "ADOPT_NEXT_PHASE",
        "DEFER_WITH_RECORD",
        "NO_ADOPTION_REQUIRED"
      ]
    },
    "decision_justification": {
      "type": "string",
      "minLength": 10
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "approver",
        "date"
      ],
      "properties": {
        "decision": {
          "enum": [
            "PENDING",
            "APPROVED",
            "REJECTED"
          ]
        },
        "approver": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
