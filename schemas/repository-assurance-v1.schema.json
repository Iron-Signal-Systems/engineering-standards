{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/repository-assurance-v1.schema.json",
  "title": "ISRAS Repository Assurance v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "standard",
    "repository",
    "canonical_origin",
    "branches",
    "validation",
    "checkpoint_registry",
    "evidence_directory",
    "source_manifest",
    "tool_requirements",
    "support_policy",
    "historical_gates_immutable",
    "native_first",
    "adoption_level"
  ],
  "properties": {
    "schema_version": {
      "const": "ISRAS-REPOSITORY-V1"
    },
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "acronym",
        "version",
        "repository",
        "commit",
        "definition"
      ],
      "properties": {
        "name": {
          "const": "Iron Signal Repository Assurance Standard"
        },
        "acronym": {
          "const": "ISRAS"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "repository": {
          "type": "string",
          "minLength": 3
        },
        "tag": {
          "type": "string",
          "pattern": "^isras-v[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "commit": {
          "type": "string",
          "pattern": "^([0-9a-f]{40}|UNPINNED-BOOTSTRAP|SELF)$"
        },
        "source_manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_manifest_sha512": {
          "type": "string",
          "pattern": "^[0-9a-f]{128}$"
        },
        "definition": {
          "type": "string",
          "minLength": 40
        }
      }
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "canonical_origin": {
      "type": "string",
      "minLength": 8
    },
    "branches": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "development",
        "release"
      ],
      "properties": {
        "development": {
          "type": "string",
          "minLength": 1
        },
        "release": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "portable_shell",
        "portable_powershell",
        "fresh_clone_shell",
        "checkpoint_shell"
      ],
      "properties": {
        "portable_shell": {
          "type": "string"
        },
        "portable_powershell": {
          "type": "string"
        },
        "fresh_clone_shell": {
          "type": "string"
        },
        "checkpoint_shell": {
          "type": "string"
        },
        "canonical_shell": {
          "type": "string"
        },
        "fresh_clone_powershell": {
          "type": "string"
        },
        "checkpoint_powershell": {
          "type": "string"
        },
        "canonical_powershell": {
          "type": "string"
        }
      }
    },
    "checkpoint_registry": {
      "type": "string"
    },
    "evidence_directory": {
      "type": "string"
    },
    "source_manifest": {
      "type": "string"
    },
    "source_manifest_sha512": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._/-]+$"
    },
    "tool_requirements": {
      "type": "string"
    },
    "support_policy": {
      "type": "string"
    },
    "documentation_sync_required": {
      "type": "boolean"
    },
    "historical_gates_immutable": {
      "const": true
    },
    "native_first": {
      "const": true
    },
    "containers_required": {
      "type": "boolean"
    },
    "direct_push_to_development_branch": {
      "type": "boolean"
    },
    "adoption_level": {
      "enum": [
        "RECORDED",
        "REPRODUCIBLE",
        "OBSERVED",
        "ENFORCED",
        "RELEASE_ASSURED"
      ]
    },
    "self_assurance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "governing_release",
        "governing_commit",
        "governing_source_manifest_sha256",
        "development_state",
        "record",
        "reassessment_trigger"
      ],
      "properties": {
        "mode": {
          "const": "PINNED_ACCEPTED_RELEASE"
        },
        "governing_release": {
          "type": "string",
          "pattern": "^isras-v[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "governing_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "governing_source_manifest_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "development_state": {
          "type": "string",
          "minLength": 40
        },
        "record": {
          "type": "string",
          "minLength": 3
        },
        "reassessment_trigger": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "adoption_level": {
            "const": "RELEASE_ASSURED"
          }
        },
        "required": [
          "adoption_level"
        ]
      },
      "then": {
        "required": [
          "self_assurance"
        ],
        "properties": {
          "standard": {
            "required": [
              "tag",
              "source_manifest_sha256"
            ],
            "properties": {
              "commit": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              }
            }
          }
        }
      }
    }
  ]
}
