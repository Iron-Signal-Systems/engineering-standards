{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/acceptance-evidence-v1.schema.json",
  "title": "ISRAS Acceptance Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "source_commit",
    "validator",
    "environment_profile",
    "correctness_result",
    "started_at",
    "finished_at",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "ISRAS-ACCEPTANCE-EVIDENCE-V1"
    },
    "repository": {
      "type": "string"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "accepted_predecessor": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{40}$"
    },
    "standard_commit": {
      "type": "string"
    },
    "validator": {
      "type": "string"
    },
    "runner_identity": {
      "type": "string"
    },
    "environment_profile": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "correctness_result": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "resource_observation": {
      "enum": [
        "RECORDED",
        "NOT_RECORDED",
        "NOT_APPLICABLE"
      ]
    },
    "performance_budget": {
      "enum": [
        "PASS",
        "FAIL",
        "NOT_EVALUATED",
        "NOT_APPLICABLE"
      ]
    },
    "security_findings": {
      "enum": [
        "NONE",
        "RECORDED",
        "NOT_EVALUATED"
      ]
    },
    "operational_readiness": {
      "enum": [
        "ACCEPTED",
        "NOT_ACCEPTED",
        "NOT_EVALUATED"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
