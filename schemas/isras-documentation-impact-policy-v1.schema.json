{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras-documentation-impact-policy-v1.schema.json",
  "title": "ISRAS Documentation Impact Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1024,
      "pattern": "^[^\\u0000\\r\\n]+$"
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "prefix": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "suffix": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        }
      },
      "oneOf": [
        {
          "required": [
            "path"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "prefix"
                ]
              },
              {
                "required": [
                  "suffix"
                ]
              }
            ]
          }
        },
        {
          "required": [
            "prefix"
          ],
          "not": {
            "required": [
              "path"
            ]
          }
        }
      ]
    },
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "$ref": "#/$defs/description"
        },
        "all": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/pattern"
          }
        },
        "any": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/pattern"
          }
        }
      },
      "oneOf": [
        {
          "required": [
            "all"
          ],
          "not": {
            "required": [
              "any"
            ]
          }
        },
        {
          "required": [
            "any"
          ],
          "not": {
            "required": [
              "all"
            ]
          }
        }
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "triggers",
        "requirements"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "description": {
          "$ref": "#/$defs/description"
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/pattern"
          }
        },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "$ref": "#/$defs/requirement"
          }
        }
      }
    }
  }
}
