{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/change-classification-v1.schema.json",
  "title": "ISRAS Change Classification v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_id",
    "base_commit",
    "selected_class",
    "impacts",
    "campaigns",
    "applicable_controls",
    "classification_rationale",
    "changed_paths_reviewed"
  ],
  "properties": {
    "schema_version": {
      "const": "ISRAS-CHANGE-CLASSIFICATION-V1"
    },
    "change_id": {
      "type": "string",
      "minLength": 3
    },
    "base_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "selected_class": {
      "enum": [
        "C0",
        "C1",
        "C2",
        "C3",
        "C4",
        "C5",
        "C6"
      ]
    },
    "impacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "editorial_only",
        "tooling",
        "implementation",
        "security_or_authority",
        "schema_or_migration",
        "acceptance_semantics",
        "release_or_recovery"
      ],
      "properties": {
        "editorial_only": {
          "type": "boolean"
        },
        "tooling": {
          "type": "boolean"
        },
        "implementation": {
          "type": "boolean"
        },
        "security_or_authority": {
          "type": "boolean"
        },
        "schema_or_migration": {
          "type": "boolean"
        },
        "acceptance_semantics": {
          "type": "boolean"
        },
        "release_or_recovery": {
          "type": "boolean"
        }
      }
    },
    "campaigns": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "applicable_controls": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^ISRAS-[A-Z]{2,4}-[0-9]{3}$"
      }
    },
    "classification_rationale": {
      "type": "string",
      "minLength": 20
    },
    "changed_paths_reviewed": {
      "const": true
    },
    "split_recommended": {
      "type": "boolean"
    }
  }
}
