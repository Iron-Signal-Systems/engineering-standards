{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Iron-Signal-Systems/engineering-standards/schemas/isras-project-command-execution-v2.schema.json",
  "title": "ISRAS Project Command Execution Evidence v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "authorization",
    "status",
    "mode",
    "command_name",
    "arguments",
    "resolved_executable",
    "working_directory",
    "environment_names",
    "timeout_seconds",
    "output_limit_bytes_per_stream",
    "started",
    "finished",
    "duration_milliseconds",
    "exit_code",
    "timed_out",
    "output_limit_exceeded",
    "repository_state_changed",
    "validator",
    "target",
    "stdout",
    "stderr"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "run_id": {
      "type": "string",
      "pattern": "^(?:[0-9a-f]{24}|fallback-[0-9]+)$"
    },
    "authorization": {
      "const": "GRANTED"
    },
    "status": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "failure": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^[^\\u0000\\r\\n]+$"
    },
    "mode": {
      "enum": [
        "development",
        "commit",
        "release"
      ]
    },
    "command_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,63}$"
    },
    "arguments": {
      "type": "array",
      "minItems": 0,
      "maxItems": 64,
      "items": {
        "type": "string",
        "maxLength": 4096,
        "pattern": "^[^\\u0000\\r\\n]*$"
      }
    },
    "resolved_executable": {
      "type": "string",
      "maxLength": 4096,
      "pattern": "^(?:|/[^\\u0000\\r\\n]*)$"
    },
    "working_directory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^/[^\\u0000\\r\\n]*$"
    },
    "environment_names": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
      }
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400
    },
    "output_limit_bytes_per_stream": {
      "type": "integer",
      "minimum": 1024,
      "maximum": 16777216
    },
    "started": {
      "type": "string",
      "format": "date-time"
    },
    "finished": {
      "type": "string",
      "format": "date-time"
    },
    "duration_milliseconds": {
      "type": "integer",
      "minimum": 0
    },
    "exit_code": {
      "type": "integer",
      "minimum": -1,
      "maximum": 255
    },
    "timed_out": {
      "type": "boolean"
    },
    "output_limit_exceeded": {
      "type": "boolean"
    },
    "repository_state_changed": {
      "type": "boolean"
    },
    "validator": {
      "$ref": "#/$defs/validator"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "stdout": {
      "$ref": "#/$defs/stream"
    },
    "stderr": {
      "$ref": "#/$defs/stream"
    },
    "go_toolchain": {
      "$ref": "#/$defs/go_toolchain"
    },
    "govulncheck": {
      "$ref": "#/$defs/govulncheck"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "PASS"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "exit_code": {
            "const": 0
          },
          "timed_out": {
            "const": false
          },
          "output_limit_exceeded": {
            "const": false
          },
          "repository_state_changed": {
            "const": false
          },
          "resolved_executable": {
            "minLength": 1
          },
          "environment_names": {
            "minItems": 1
          }
        },
        "not": {
          "required": [
            "failure"
          ]
        }
      },
      "else": {
        "required": [
          "failure"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "PASS"
          },
          "go_toolchain": {
            "type": "object"
          }
        },
        "required": [
          "status",
          "go_toolchain"
        ]
      },
      "then": {
        "properties": {
          "go_toolchain": {
            "properties": {
              "selected_go_executable": {
                "minLength": 1
              },
              "selected_go_directory": {
                "minLength": 1
              },
              "selected_go_version": {
                "minLength": 1
              },
              "project_go_minimum": {
                "minLength": 1
              },
              "go_minimum_satisfied": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command_name": {
            "const": "known_vulnerabilities"
          },
          "status": {
            "const": "PASS"
          }
        },
        "required": [
          "command_name",
          "status"
        ]
      },
      "then": {
        "required": [
          "govulncheck"
        ],
        "properties": {
          "govulncheck": {
            "required": [
              "exceptions"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$",
      "not": {
        "const": "0000000000000000000000000000000000000000"
      }
    },
    "digest256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "digest512": {
      "type": "string",
      "pattern": "^[0-9a-f]{128}$"
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "version",
        "release_tag",
        "source_repository",
        "source_commit"
      ],
      "properties": {
        "profile": {
          "const": "ISRAS-SD"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "release_tag": {
          "type": "string",
          "pattern": "^isras-v[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "source_repository": {
          "const": "github.com/Iron-Signal-Systems/engineering-standards"
        },
        "source_commit": {
          "$ref": "#/$defs/commit"
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "root",
        "commit",
        "origin"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^github\\.com/Iron-Signal-Systems/[A-Za-z0-9][A-Za-z0-9._-]{0,99}$"
        },
        "root": {
          "type": "string",
          "pattern": "^/[^\\u0000\\r\\n]*$"
        },
        "commit": {
          "$ref": "#/$defs/commit"
        },
        "branch": {
          "type": "string",
          "maxLength": 1024,
          "pattern": "^[^\\u0000\\r\\n]*$"
        },
        "origin": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n]+$"
        }
      }
    },
    "stream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bytes",
        "sha256",
        "sha512",
        "sanitized_output",
        "limit_exceeded",
        "redaction_boundary"
      ],
      "properties": {
        "bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 16777216
        },
        "sha256": {
          "$ref": "#/$defs/digest256"
        },
        "sha512": {
          "$ref": "#/$defs/digest512"
        },
        "sanitized_output": {
          "type": "string",
          "maxLength": 16777216
        },
        "limit_exceeded": {
          "type": "boolean"
        },
        "redaction_boundary": {
          "const": "credential-shaped values are redacted; raw output is not retained"
        }
      }
    },
    "go_toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_go_executable",
        "selected_go_directory",
        "selected_go_version",
        "project_go_minimum",
        "GOTOOLCHAIN_effective",
        "GOENV_effective",
        "go_minimum_satisfied",
        "modules"
      ],
      "properties": {
        "selected_go_executable": {
          "type": "string",
          "maxLength": 4096,
          "pattern": "^(?:|/[^\\u0000\\r\\n]*)$"
        },
        "selected_go_directory": {
          "type": "string",
          "maxLength": 4096,
          "pattern": "^(?:|/[^\\u0000\\r\\n]*)$"
        },
        "selected_go_version": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^(?:|go[0-9][^\\u0000\\r\\n ]*)$"
        },
        "project_go_minimum": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^(?:|go[0-9][^\\u0000\\r\\n ]*)$"
        },
        "project_toolchain_directive": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^(?:default|go[0-9][^\\u0000\\r\\n ]*)$"
        },
        "GOTOOLCHAIN_effective": {
          "const": "local"
        },
        "GOENV_effective": {
          "const": "off"
        },
        "go_minimum_satisfied": {
          "type": "boolean"
        },
        "modules": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/go_module"
          }
        }
      }
    },
    "go_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "go_mod_path",
        "directory",
        "module_path",
        "go_minimum",
        "go_minimum_satisfied"
      ],
      "properties": {
        "go_mod_path": {
          "type": "string",
          "pattern": "^(?:go\\.mod|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*/go\\.mod)$",
          "maxLength": 4096
        },
        "directory": {
          "type": "string",
          "pattern": "^(?:\\.|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*)$",
          "maxLength": 4096
        },
        "module_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        },
        "go_minimum": {
          "type": "string",
          "pattern": "^go[0-9][^\\u0000\\r\\n ]*$",
          "maxLength": 256
        },
        "toolchain_directive": {
          "type": "string",
          "pattern": "^(?:default|go[0-9][^\\u0000\\r\\n ]*)$",
          "maxLength": 256
        },
        "go_minimum_satisfied": {
          "type": "boolean"
        }
      }
    },
    "govulncheck_protocol_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "version"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n]+$"
        },
        "version": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^[^\\u0000\\r\\n]*$"
        }
      }
    },
    "govulncheck_protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "scanner_name",
        "scanner_version",
        "database",
        "database_last_modified",
        "go_version",
        "scan_level",
        "scan_mode",
        "message_count",
        "config_messages",
        "progress_messages",
        "sbom_messages",
        "osv_messages",
        "finding_messages",
        "sbom_roots",
        "sbom_modules",
        "osv_advisory_ids",
        "finding_advisory_ids",
        "module_level_findings",
        "package_level_findings",
        "symbol_level_findings",
        "unknown_level_findings"
      ],
      "properties": {
        "protocol_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[^\\u0000\\r\\n]+$"
        },
        "scanner_name": {
          "const": "govulncheck"
        },
        "scanner_version": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9._-]+)?$",
          "maxLength": 256
        },
        "database": {
          "type": "string",
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n]*$"
        },
        "database_last_modified": {
          "type": "string",
          "maxLength": 256,
          "pattern": "^[^\\u0000\\r\\n]*$"
        },
        "go_version": {
          "type": "string",
          "pattern": "^go[0-9][^\\u0000\\r\\n ]*$",
          "maxLength": 256
        },
        "scan_level": {
          "const": "symbol"
        },
        "scan_mode": {
          "const": "source"
        },
        "message_count": {
          "type": "integer",
          "minimum": 1
        },
        "config_messages": {
          "const": 1
        },
        "progress_messages": {
          "type": "integer",
          "minimum": 0
        },
        "sbom_messages": {
          "type": "integer",
          "minimum": 0
        },
        "osv_messages": {
          "type": "integer",
          "minimum": 0
        },
        "finding_messages": {
          "type": "integer",
          "minimum": 0
        },
        "sbom_roots": {
          "type": "array",
          "maxItems": 65536,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "pattern": "^[^\\u0000\\r\\n]+$"
          }
        },
        "sbom_modules": {
          "type": "array",
          "maxItems": 65536,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/govulncheck_protocol_module"
          }
        },
        "osv_advisory_ids": {
          "type": "array",
          "maxItems": 65536,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
          }
        },
        "finding_advisory_ids": {
          "type": "array",
          "maxItems": 65536,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
          }
        },
        "module_level_findings": {
          "type": "integer",
          "minimum": 0
        },
        "package_level_findings": {
          "type": "integer",
          "minimum": 0
        },
        "symbol_level_findings": {
          "type": "integer",
          "minimum": 0
        },
        "unknown_level_findings": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "govulncheck_module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "go_mod_path",
        "directory",
        "module_path",
        "package_scope",
        "environment_names",
        "started",
        "finished",
        "duration_milliseconds",
        "exit_code",
        "timed_out",
        "output_limit_exceeded",
        "repository_state_changed",
        "protocol",
        "stdout",
        "stderr"
      ],
      "properties": {
        "go_mod_path": {
          "type": "string",
          "pattern": "^(?:go\\.mod|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*/go\\.mod)$",
          "maxLength": 4096
        },
        "directory": {
          "type": "string",
          "pattern": "^(?:\\.|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*)$",
          "maxLength": 4096
        },
        "module_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        },
        "package_scope": {
          "const": "./..."
        },
        "environment_names": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
          }
        },
        "started": {
          "type": "string",
          "format": "date-time"
        },
        "finished": {
          "type": "string",
          "format": "date-time"
        },
        "duration_milliseconds": {
          "type": "integer",
          "minimum": 0
        },
        "exit_code": {
          "type": "integer",
          "minimum": -1,
          "maximum": 255
        },
        "timed_out": {
          "type": "boolean"
        },
        "output_limit_exceeded": {
          "type": "boolean"
        },
        "repository_state_changed": {
          "type": "boolean"
        },
        "protocol": {
          "$ref": "#/$defs/govulncheck_protocol"
        },
        "stdout": {
          "$ref": "#/$defs/stream"
        },
        "stderr": {
          "$ref": "#/$defs/stream"
        }
      }
    },
    "govulncheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executable",
        "directory",
        "approved_command_package",
        "embedded_module",
        "version",
        "build_go_version",
        "sha256",
        "package_scope",
        "GOTOOLCHAIN_effective",
        "GOENV_effective",
        "modules"
      ],
      "properties": {
        "executable": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^/[^\\u0000\\r\\n]*$"
        },
        "directory": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^/[^\\u0000\\r\\n]*$"
        },
        "approved_command_package": {
          "const": "golang.org/x/vuln/cmd/govulncheck"
        },
        "embedded_module": {
          "const": "golang.org/x/vuln"
        },
        "version": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9._-]+)?$",
          "maxLength": 256
        },
        "build_go_version": {
          "type": "string",
          "pattern": "^go[0-9][^\\u0000\\r\\n ]*$",
          "maxLength": 256
        },
        "sha256": {
          "$ref": "#/$defs/digest256"
        },
        "package_scope": {
          "const": "./..."
        },
        "GOTOOLCHAIN_effective": {
          "const": "local"
        },
        "GOENV_effective": {
          "const": "off"
        },
        "modules": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/govulncheck_module"
          }
        },
        "exceptions": {
          "$ref": "#/$defs/govulncheck_exceptions"
        }
      }
    },
    "govulncheck_exception_scope_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "go_mod_path",
        "module_path",
        "package_path",
        "symbol"
      ],
      "properties": {
        "go_mod_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^(?:go\\.mod|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*/go\\.mod)$"
        },
        "module_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        },
        "package_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        },
        "symbol": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        }
      }
    },
    "govulncheck_exception_approval_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved_by",
        "approved_at",
        "record"
      ],
      "properties": {
        "approved_by": {
          "type": "string",
          "minLength": 3,
          "maxLength": 512,
          "pattern": "^[^\\u0000\\r\\n]+$"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "record": {
          "type": "string",
          "minLength": 3,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n]+$"
        }
      }
    },
    "govulncheck_exception_remediation_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "target_date",
        "plan"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 3,
          "maxLength": 512,
          "pattern": "^[^\\u0000\\r\\n]+$"
        },
        "target_date": {
          "type": "string",
          "format": "date",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "plan": {
          "type": "string",
          "minLength": 20,
          "maxLength": 8192,
          "pattern": "^[^\\u0000\\r\\n]+$"
        }
      }
    },
    "govulncheck_exception_record_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_id",
        "scope",
        "justification",
        "compensating_controls",
        "owner",
        "approval",
        "expires_at",
        "remediation"
      ],
      "properties": {
        "advisory_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
        },
        "scope": {
          "$ref": "#/$defs/govulncheck_exception_scope_evidence"
        },
        "justification": {
          "type": "string",
          "minLength": 20,
          "maxLength": 8192,
          "pattern": "^[^\\u0000\\r\\n]+$"
        },
        "compensating_controls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 10,
            "maxLength": 2048,
            "pattern": "^[^\\u0000\\r\\n]+$"
          }
        },
        "owner": {
          "type": "string",
          "minLength": 3,
          "maxLength": 512,
          "pattern": "^[^\\u0000\\r\\n]+$"
        },
        "approval": {
          "$ref": "#/$defs/govulncheck_exception_approval_evidence"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "remediation": {
          "$ref": "#/$defs/govulncheck_exception_remediation_evidence"
        }
      }
    },
    "govulncheck_finding_occurrence_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_id",
        "go_mod_path",
        "module_path",
        "package_path",
        "symbol",
        "fixed_versions",
        "occurrences"
      ],
      "properties": {
        "advisory_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
        },
        "go_mod_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^(?:go\\.mod|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*/go\\.mod)$"
        },
        "module_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        },
        "package_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        },
        "symbol": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^[^\\u0000\\r\\n\\t \\\\]+$"
        },
        "fixed_versions": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[^\\u0000\\r\\n ]+$"
          }
        },
        "occurrences": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "govulncheck_used_exception_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exception",
        "finding"
      ],
      "properties": {
        "exception": {
          "$ref": "#/$defs/govulncheck_exception_record_evidence"
        },
        "finding": {
          "$ref": "#/$defs/govulncheck_finding_occurrence_evidence"
        }
      }
    },
    "govulncheck_unknown_finding_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "go_mod_path",
        "occurrences"
      ],
      "properties": {
        "go_mod_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^(?:go\\.mod|[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*/go\\.mod)$"
        },
        "occurrences": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "govulncheck_exceptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "present",
        "path",
        "sha256",
        "schema_version",
        "evaluated_at",
        "used",
        "unused",
        "unexcepted",
        "unknown"
      ],
      "properties": {
        "present": {
          "type": "boolean"
        },
        "path": {
          "const": ".isras/govulncheck-exceptions.json"
        },
        "sha256": {
          "type": "string",
          "pattern": "^(?:|[0-9a-f]{64})$"
        },
        "schema_version": {
          "const": 1
        },
        "evaluated_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "used": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/govulncheck_used_exception_evidence"
          }
        },
        "unused": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/govulncheck_exception_record_evidence"
          }
        },
        "unexcepted": {
          "type": "array",
          "maxItems": 65536,
          "items": {
            "$ref": "#/$defs/govulncheck_finding_occurrence_evidence"
          }
        },
        "unknown": {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/govulncheck_unknown_finding_evidence"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "present": {
                "const": true
              }
            },
            "required": [
              "present"
            ]
          },
          "then": {
            "properties": {
              "sha256": {
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "present": {
                "const": false
              }
            },
            "required": [
              "present"
            ]
          },
          "then": {
            "properties": {
              "sha256": {
                "const": ""
              },
              "used": {
                "maxItems": 0
              },
              "unused": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    }
  }
}
