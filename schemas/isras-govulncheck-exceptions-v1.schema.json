{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras-govulncheck-exceptions-v1.schema.json",
  "title": "ISRAS Govulncheck Exception Document v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exceptions"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "exceptions": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/exception"
      }
    }
  },
  "$defs": {
    "single_line_3": {
      "type": "string",
      "minLength": 3,
      "maxLength": 4096,
      "pattern": "^[^\\u0000\\r\\n]+$"
    },
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "advisory_id",
        "scope",
        "justification",
        "compensating_controls",
        "owner",
        "approval",
        "expires_at",
        "remediation"
      ],
      "properties": {
        "advisory_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,255}$"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "justification": {
          "type": "string",
          "minLength": 20,
          "maxLength": 8192,
          "pattern": "^[^\\u0000\\r\\n]+$"
        },
        "compensating_controls": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 10,
            "maxLength": 2048,
            "pattern": "^[^\\u0000\\r\\n]+$"
          }
        },
        "owner": {
          "$ref": "#/$defs/single_line_3"
        },
        "approval": {
          "$ref": "#/$defs/approval"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "remediation": {
          "$ref": "#/$defs/remediation"
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "go_mod_path",
        "module_path",
        "package_path",
        "symbol"
      ],
      "properties": {
        "go_mod_path": {
          "type": "string",
          "maxLength": 4096,
          "pattern": "^(?:go\\.mod|(?!(?:\\.local)(?:/|$))[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*/go\\.mod)$"
        },
        "module_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t *?\\[\\\\]+$"
        },
        "package_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "pattern": "^[^\\u0000\\r\\n\\t *?\\[\\\\]+$"
        },
        "symbol": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^(?:\\(\\*[A-Za-z_][A-Za-z0-9_]*\\)\\.)?[A-Za-z_][A-Za-z0-9_.]*$"
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved_by",
        "approved_at",
        "record"
      ],
      "properties": {
        "approved_by": {
          "$ref": "#/$defs/single_line_3"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "record": {
          "$ref": "#/$defs/single_line_3"
        }
      }
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "target_date",
        "plan"
      ],
      "properties": {
        "owner": {
          "$ref": "#/$defs/single_line_3"
        },
        "target_date": {
          "type": "string",
          "format": "date",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "plan": {
          "type": "string",
          "minLength": 20,
          "maxLength": 8192,
          "pattern": "^[^\\u0000\\r\\n]+$"
        }
      }
    }
  }
}
