{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/evidence-binding-v1.schema.json",
  "title": "ISRAS Evidence Binding v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "campaign_id",
    "candidate_commit",
    "environment_artifact",
    "declared_test_ids",
    "validators",
    "artifacts",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "const": "ISRAS-EVIDENCE-BINDING-V1"
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "campaign_id": {
      "type": "string",
      "minLength": 3
    },
    "candidate_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "environment_artifact": {
      "$ref": "#/$defs/file_identity"
    },
    "declared_test_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "validator_id",
          "version",
          "source_commit",
          "executable_path",
          "executable_sha512"
        ],
        "properties": {
          "validator_id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "source_commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{40}$"
          },
          "executable_path": {
            "type": "string",
            "minLength": 1
          },
          "executable_sha512": {
            "type": "string",
            "pattern": "^[0-9a-f]{128}$"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "path",
          "sha512",
          "validator_id",
          "test_ids",
          "identity_probe",
          "outcome_probe"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha512": {
            "type": "string",
            "pattern": "^[0-9a-f]{128}$"
          },
          "validator_id": {
            "type": "string",
            "minLength": 1
          },
          "test_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "identity_probe": {
            "oneOf": [
              {
                "$ref": "#/$defs/text_identity"
              },
              {
                "$ref": "#/$defs/json_identity"
              }
            ]
          },
          "outcome_probe": {
            "oneOf": [
              {
                "$ref": "#/$defs/text_outcome"
              },
              {
                "$ref": "#/$defs/json_outcome"
              }
            ]
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "control_id",
          "required_test_ids",
          "artifact_ids",
          "expected_outcome"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "control_id": {
            "type": "string",
            "pattern": "^ISRAS-[A-Z]{2,4}-[0-9]{3}$"
          },
          "required_test_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "artifact_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "expected_outcome": {
            "const": "PASS"
          }
        }
      }
    }
  },
  "$defs": {
    "file_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha512"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha512": {
          "type": "string",
          "pattern": "^[0-9a-f]{128}$"
        }
      }
    },
    "json_path": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": [
          "string",
          "integer"
        ]
      }
    },
    "text_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "candidate_commit_marker",
        "campaign_id_marker",
        "environment_sha512_marker"
      ],
      "properties": {
        "format": {
          "const": "TEXT"
        },
        "candidate_commit_marker": {
          "type": "string",
          "minLength": 1
        },
        "campaign_id_marker": {
          "type": "string",
          "minLength": 1
        },
        "environment_sha512_marker": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "json_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "candidate_commit_path",
        "campaign_id_path",
        "environment_sha512_path"
      ],
      "properties": {
        "format": {
          "const": "JSON"
        },
        "candidate_commit_path": {
          "$ref": "#/$defs/json_path"
        },
        "campaign_id_path": {
          "$ref": "#/$defs/json_path"
        },
        "environment_sha512_path": {
          "$ref": "#/$defs/json_path"
        }
      }
    },
    "text_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "pass_marker"
      ],
      "properties": {
        "format": {
          "const": "TEXT_ISRAS_SUMMARY"
        },
        "pass_marker": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "json_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "json_path",
        "expected"
      ],
      "properties": {
        "format": {
          "const": "JSON"
        },
        "json_path": {
          "$ref": "#/$defs/json_path"
        },
        "expected": {}
      }
    }
  }
}
